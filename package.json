{
  "name": "celoria-ai-landing",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3003",
    "build": "next build",
    "start": "next start -p 3003",
    "lint": "next lint",
    "test:unit": "TEST_REPORT_TYPE=frontend vitest run tests/unit --config vitest.config.mjs",
    "test:integration": "TEST_REPORT_TYPE=integration vitest run tests/integration --config vitest.config.mjs",
    "test:e2e": "playwright test -c playwright.e2e.config.ts",
    "capture-screenshots": "npx playwright test scripts/capture-screenshots.ts --project=chromium",
    "capture-screenshots:standalone": "npx ts-node scripts/capture-screenshots.ts"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.1.6",
    "flexsearch": "^0.8.212",
    "gray-matter": "^4.0.3",
    "next": "^15.1.0",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  }
